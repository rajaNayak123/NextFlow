generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workflow {
  id      String @id @default(cuid())
  name    String @default("Untitled Workflow")
  userId  String
  nodes   Json
  edges   Json
  status  String @default("idle") // idle, running, completed, failed
  version Int    @default(1)

  executions Execution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Execution {
  id         String  @id @default(cuid())
  workflowId String
  userId     String
  status     String // pending, running, completed, failed, partial
  type       String // full, partial, single
  duration   Float? // seconds
  nodes      Json // node execution details
  error      String?

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
